.login-modal__mask {
  position: fixed;
  inset: 0;
  background: rgba(11, 18, 34, 0.48);
  z-index: 1000;
}

.login-modal__dialog {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 1001;
  padding: 0;
  overflow: hidden;
}

.login-modal__header {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 30rpx 30rpx 18rpx;
}

.login-modal__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #172033;
}

.login-modal__tip {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7890;
}

.login-modal__close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(67, 81, 108, 0.08);
  color: #6b7890;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
}

.login-modal__body {
  padding: 0 30rpx 30rpx;
}

.login-modal__btn {
  margin-top: 14rpx;
}
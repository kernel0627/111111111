.post-card {
  position: relative;
  overflow: hidden;
  padding: 0;
  border: 1rpx solid rgba(218, 226, 240, 0.92);
  background: linear-gradient(180deg, #fffef9 0%, #fbfbf5 52%, #f7f7f0 100%);
  box-shadow: 0 18rpx 44rpx rgba(66, 90, 138, 0.1);
}

.post-card--hover {
  transform: scale(0.99);
}

.post-card__inner {
  position: relative;
  z-index: 1;
  padding: 26rpx;
}

.post-card__glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(16rpx);
  opacity: 0.75;
  z-index: 0;
  background: rgba(208, 220, 245, 0.42);
}

.post-card__glow--one {
  top: -48rpx;
  right: -22rpx;
  width: 188rpx;
  height: 188rpx;
}

.post-card__glow--two {
  left: -40rpx;
  bottom: 112rpx;
  width: 164rpx;
  height: 164rpx;
  background: rgba(243, 238, 208, 0.36);
}

.post-card__top {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  justify-content: space-between;
}

.post-card__main {
  flex: 1;
  min-width: 0;
}

.post-card__badge-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}

.post-card__title {
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #172033;
}

.post-card__desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.72;
  color: #5d6d88;
}

.post-card__category {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #4862a8;
  background: rgba(101, 124, 186, 0.12);
}

.post-card__status {
  font-size: 21rpx;
}

.post-card__meta-shell {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
}

.post-card__meta .meta-line {
  gap: 8rpx;
  font-size: 23rpx;
  color: #3e4c68;
}

.post-card__meta .meta-icon {
  width: 20rpx;
  height: 20rpx;
  margin-top: 7rpx;
}

.post-card__bottom {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 42rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  background: rgb(255, 255, 235);
  border: 1rpx solid rgba(241, 237, 208, 0.96);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.82),
    0 8rpx 18rpx rgba(94, 116, 155, 0.06);
}

.post-card__bottom-chip {
  flex-shrink: 0;
  max-width: 240rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #546685;
  background: rgba(84, 102, 133, 0.1);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-card__author {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #44526d;
}

.post-card__author-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-card__avatar {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(219, 225, 236, 0.9);
  flex-shrink: 0;
}

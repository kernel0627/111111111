.settlement-page {
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.settlement-page .surface-card {
  background: #ffffff;
  border-color: rgba(214, 224, 242, 0.92);
  backdrop-filter: none;
}

.settlement-page .hero-card {
  background: #ffffff;
}

.settlement-hero {
  padding: 30rpx;
}

.settlement-hero__top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.settlement-hero__content {
  flex: 1;
  min-width: 0;
}

.settlement-flow-badge {
  min-width: 96rpx;
  padding: 14rpx 16rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #edf4ff 0%, #dfeaff 100%);
  border: 1rpx solid rgba(85, 128, 230, 0.22);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  flex-shrink: 0;
}

.settlement-flow-badge__line {
  font-size: 22rpx;
  line-height: 1.2;
  color: #356dff;
  font-weight: 700;
}

.settlement-hero__meta {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #6b7890;
}

.member-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
}

.member-card--active {
  border: 2rpx solid rgba(53, 109, 255, 0.25);
  background: #f6f9ff;
}

.member-card__avatar {
  width: 82rpx;
  height: 82rpx;
  border-radius: 50%;
  background: #e8efff;
  flex-shrink: 0;
}

.member-card__info {
  flex: 1;
  min-width: 0;
}

.member-card__name {
  font-size: 30rpx;
  color: #172033;
  font-weight: 700;
}

.member-card__status,
.member-card__time {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7890;
}

.member-inline {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.note-card {
  padding: 28rpx;
}

.note-card__input {
  width: 100%;
  min-height: 180rpx;
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f7f9fd;
  color: #283752;
}

.state-card {
  padding: 28rpx;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  z-index: 20;
}

.sheet-panel,
.confirm-card {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 21;
  padding: 28rpx;
}

.sheet-panel__title {
  font-size: 32rpx;
  color: #172033;
  font-weight: 700;
}

.sheet-panel__subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7890;
}

.sheet-panel__actions,
.confirm-card__actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.sheet-panel__btn {
  width: 100%;
}

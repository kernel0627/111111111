<view class="page-shell auth-page">
  <view class="surface-card hero-card auth-card">
    <view class="auth-card__title">注册账号</view>
    <view class="auth-card__desc">注册后会自动登录，后续所有活动、评分和群聊记录都会和这个账号绑定。</view>

    <view class="input-shell auth-card__field">
      <input class="auth-card__input" placeholder="昵称（唯一）" value="{{nickname}}" bindinput="onNicknameInput" confirm-type="next" />
    </view>
    <view class="input-shell auth-card__field">
      <input class="auth-card__input" placeholder="密码（至少 6 位）" password value="{{password}}" bindinput="onPasswordInput" confirm-type="next" />
    </view>
    <view class="input-shell auth-card__field">
      <input class="auth-card__input" placeholder="确认密码" password value="{{confirmPassword}}" bindinput="onConfirmInput" confirm-type="done" bindconfirm="onSubmit" />
    </view>

    <button class="primary-btn auth-card__submit" bindtap="onSubmit" loading="{{submitting}}">注册并登录</button>
    <button class="ghost-btn auth-card__switch" bindtap="onGoLogin">已有账号？去登录</button>
  </view>
</view>

.profile-hero {
  padding: 30rpx;
}

.profile-hero__top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.profile-hero__user {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.profile-avatar-wrap {
  position: relative;
  width: 116rpx;
  height: 116rpx;
  flex-shrink: 0;
}

.profile-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #e8efff;
}

.profile-avatar-btn {
  position: absolute;
  right: -4rpx;
  top: -4rpx;
  width: 42rpx;
  height: 42rpx;
  min-width: 42rpx;
  padding: 0;
  border-radius: 50%;
  background: #ffffff;
  color: #2f5bff;
  border: 1rpx solid rgba(194, 208, 234, 0.9);
  font-size: 20rpx;
}

.profile-hero__meta {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 36rpx;
  color: #172033;
  font-weight: 700;
}

.profile-role {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7890;
}

.profile-logout {
  min-width: 180rpx;
  height: 72rpx;
  font-size: 26rpx;
  border-radius: 18rpx;
}

.profile-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.profile-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 26rpx;
}

.profile-credit-link {
  width: 100%;
  margin-top: 18rpx;
}

.profile-stat {
  padding: 22rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(246, 249, 255, 0.95);
  text-align: center;
}

.profile-stat__num {
  font-size: 38rpx;
  font-weight: 700;
  color: #2f5bff;
}

.profile-stat__label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7890;
}

.tabs-card {
  padding: 10rpx;
}

.tabs-nav {
  display: flex;
  gap: 10rpx;
}

.tabs-nav__item {
  flex: 1;
  height: 76rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #586782;
}

.tabs-nav__item--active {
  color: #ffffff;
  background: linear-gradient(135deg, #356dff 0%, #5b84ff 100%);
  box-shadow: 0 10rpx 22rpx rgba(53, 109, 255, 0.2);
}

.project-card {
  padding: 26rpx;
}

.project-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.project-card__title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.5;
  color: #172033;
  font-weight: 700;
}

.project-card__time {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7a869a;
}

.project-card__score,
.project-card__preview {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #4f5f7b;
  line-height: 1.7;
}

.project-card__action {
  width: 100%;
  margin-top: 18rpx;
}

.login-entry {
  width: 100%;
  margin-top: 28rpx;
}

.home-hero__row { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; }
.home-hero__title { font-size: 42rpx; font-weight: 700; color: #172033; }
.home-hero__desc { margin-top: 10rpx; font-size: 24rpx; line-height: 1.7; color: #6b7890; }
.home-hero__chat { width: 92rpx; height: 92rpx; border-radius: 28rpx; background: rgba(53, 109, 255, 0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.home-hero__chat-icon { width: 42rpx; height: 42rpx; }
.filter-card { padding: 18rpx; }
.filter-card__row { display: flex; align-items: center; gap: 14rpx; }
.filter-card__input { flex: 1; }
.filter-card__btn { width: 150rpx; height: 92rpx; border-radius: 22rpx; font-size: 26rpx; }
.filter-card__location { min-width: 148rpx; max-width: 190rpx; height: 92rpx; border-radius: 22rpx; font-size: 27rpx; color: #35518e; background: rgba(244, 247, 255, 0.96); border: 1rpx solid rgba(194, 208, 234, 0.9); display: flex; gap: 8rpx; align-items: center; justify-content: center; padding: 0 18rpx; }
.filter-card__location-text { min-width: 0; max-width: 114rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.filter-card__arrow { font-size: 20rpx; color: #6a7897; }
.list-footer { text-align: center; padding: 12rpx 0 20rpx; font-size: 24rpx; }
.home-create-btn { position: fixed; right: 24rpx; bottom: calc(118rpx + env(safe-area-inset-bottom)); width: 108rpx; height: 108rpx; border-radius: 50%; background: linear-gradient(135deg, #356dff 0%, #5b84ff 100%); color: #ffffff; box-shadow: 0 16rpx 32rpx rgba(53, 109, 255, 0.24); font-size: 54rpx; font-weight: 400; line-height: 1; padding: 0; display: flex; align-items: center; justify-content: center; z-index: 88; }
.home-create-btn__plus { display: block; font-size: 58rpx; line-height: 1; transform: translateY(-2rpx); }
.sheet-mask { position: fixed; inset: 0; background: rgba(19, 30, 54, 0.34); z-index: 90; }
.sheet-panel { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(30rpx + env(safe-area-inset-bottom)); padding: 28rpx; z-index: 91; }
.sheet-panel__title { font-size: 34rpx; font-weight: 700; color: #172033; }
.sheet-panel__subtitle { margin-top: 10rpx; font-size: 24rpx; line-height: 1.7; color: #6b7890; }
.sheet-panel__actions { margin-top: 24rpx; display: grid; gap: 14rpx; }
.sheet-panel__btn { width: 100%; }
.manual-location-card { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(30rpx + env(safe-area-inset-bottom)); padding: 28rpx; z-index: 91; }
.manual-location-card__input { margin-top: 22rpx; }
.manual-location-card__actions { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14rpx; margin-top: 22rpx; }
